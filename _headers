# Cloudflare Pages HTTP headers
# (Cloudflare Pages reads this file — NOT netlify.toml)

# Long-cache static images (filenames stable; CMS uploads get unique names)
/images/*
  Cache-Control: public, max-age=31536000, immutable

# Logo & favicon — weekly cache
/logo.png
  Cache-Control: public, max-age=604800

# Fonts/CSS/JS — moderate cache with revalidation
/style.css
  Cache-Control: public, max-age=86400
/*.js
  Cache-Control: public, max-age=86400

# Content JSON must stay fresh so CMS edits appear immediately
/content/*
  Cache-Control: public, max-age=0, must-revalidate

# Security headers for all pages
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
